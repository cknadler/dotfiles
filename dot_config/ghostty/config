# Shell integration: semantic prompts, cursor tracking, sudo handling
shell-integration = zsh

# Block cursor to match vim/nvim
cursor-style = block
cursor-style-blink = false

# Selection goes straight to clipboard
copy-on-select = clipboard

# No "close this terminal?" confirmation
confirm-close-surface = false

# Font
font-family = JetBrains Mono
font-size = 14

# Padding
window-padding-x = 8
window-padding-y = 4

# Theme — run `ghostty +list-themes` to browse all options
# theme = catppuccin-mocha
